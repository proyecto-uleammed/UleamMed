# Configuracion base del backend UleamMed

PROJECT_NAME=UleamMed API
VERSION=0.1.0
API_V1_PREFIX=/api/v1

# Esta URL debe ajustarse cuando Andy de BD confirme usuario, clave y nombre de base.
DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/uleammed

# Cambiar por una cadena larga y secreta en desarrollo real.
SECRET_KEY=change-this-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Opcional. Si no existe, las notificaciones quedan como simuladas.
FIREBASE_CREDENTIALS=./firebase-credentials.json

ENVIRONMENT=development
