# Configuracion base del backend UleamMed

PROJECT_NAME=UleamMed API
VERSION=0.1.0
API_V1_PREFIX=/api/v1

# Esta URL debe ajustarse cuando Andyy de BD confirme usuario, clave y nombre de base.
DATABASE_URL=postgresql+psycopg://USUARIO:CONTRASENA@HOST:PUERTO/NOMBRE_BD

# Cambiar por una cadena larga, aleatoria y secreta en desarrollo real.
SECRET_KEY=REEMPLAZAR_POR_CLAVE_SECRETA_LARGA
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Opcional. Si no existe o no apunta a un JSON real, las notificaciones quedan como simuladas.
FIREBASE_CREDENTIALS=./firebase-credentials.example.json

ENVIRONMENT=development
